rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile pictures: each signed-in user can only manage their own avatar file(s).
    match /profilePictures/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Legacy flat profile picture paths used by older builds.
    match /profilePictures/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && fileName.matches('^' + request.auth.uid + '\\.(jpg|jpeg|png|webp)$');
    }
  }
}
